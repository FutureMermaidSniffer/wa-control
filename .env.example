# WA Control - Rocket-style raw control system
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wa_control
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (for BullMQ + realtime pubsub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Baileys / WA
BAILEYS_BROWSER=Chrome (Linux)
# Auth state will be stored in DB primarily; this is backup dir
AUTH_STATE_DIR=./auth-state

# Pairing handshake verification gate (opt-in; Zod default is 0)
# When 1: pairing codes exposed only after WA accepts companion_hello
PAIRING_HANDSHAKE_GATE=1
# companion_hello accept window (ms). Increase for slow residential proxies.
HANDSHAKE_WAIT_MS=45000
HANDSHAKE_WEAK_ACCEPT_MS=25000
# 1 = allow weak accept under gate (debug; not proof of phone notification)
HANDSHAKE_ALLOW_WEAK_WITH_GATE=0
# companion_hello attempts per /sessions/connect (recovery retries)
PAIRING_HELLO_ATTEMPTS=3
PAIRING_AUTO_RETRY_ON_FAILURE=1
WA_BROWSER=mac
# Baileys socket open wait through proxy (ms)
SOCKET_READY_TIMEOUT_MS=60000

# Proxies (defaults, can be per-proxy in DB)
DEFAULT_PROXY_TIMEOUT_MS=10000

# Storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Logging
LOG_LEVEL=info

# Encryption for sensitive data (Baileys auth state, proxy passwords, etc.)
# Must be at least 32 characters
ENCRYPTION_KEY=change-this-to-a-strong-32-byte-secret-for-prod

# For testing real flows, add your test numbers/proxies later (never commit real creds)

# MoreLogin Cloud Phone Emulator (replaces local Waydroid)
# Get from MoreLogin desktop: Settings → API & MCP
MORELOGIN_API_ID=your_api_id_here
MORELOGIN_API_KEY=your_api_key_here
MORELOGIN_LOCAL_API=http://127.0.0.1:40000
MORELOGIN_DEFAULT_SKU_ID=10004
MORELOGIN_MODE=open

# Meta WhatsApp Cloud API webhooks (App Dashboard → WhatsApp → Configuration)
# Callback URL: https://YOUR_DOMAIN/api/v1/webhooks/whatsapp
WHATSAPP_VERIFY_TOKEN=choose-a-long-random-verify-string
WHATSAPP_APP_SECRET=
