{
  "name": "wa-control",
  "version": "0.1.0",
  "description": "Raw control WhatsApp multi-account system modeled after Rocket WS Cloud Control (PDF) - built on Baileys for full linked-device control, proxies, warming, ports, desks, blasts, groups. Completely separate from prior SaaS.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "scrape-proxies": "node src/scripts/proxy-scraper.js",
    "provision-waydroid": "node src/scripts/provision-waydroid.js",
    "test": "NODE_ENV=test node --test tests/*.test.js || echo 'Add jest or native tests'",
    "test:watch": "echo 'configure test watcher'",
    "lint": "echo 'add eslint later'"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "multi-account",
    "cloud-control",
    "warming",
    "养号",
    "ports",
    "proxy",
    "raw-control"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "https-proxy-agent": "^9.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "socks-proxy-agent": "^8.0.5",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
